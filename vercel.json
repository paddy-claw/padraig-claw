{
  "version": 2,
  "routes": [
    {
      "src": "/api/room",
      "dest": "/api/room.js"
    },
{
      "src": "/api/health",
      "dest": "/api/health.js"
    },
    {
      "src": "/api/newsletter",
      "dest": "/api/newsletter.js"
    },
    {
      "src": "/api/unsubscribe",
      "dest": "/api/unsubscribe.js"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/showcase",
      "dest": "/showcase.html"
    },
    {
      "src": "/admin",
      "dest": "/admin.html"
    },
    {
      "src": "/privacy",
      "dest": "/privacy.html"
    },
    {
      "src": "/robots.txt",
      "dest": "/robots.txt",
      "headers": {
        "Cache-Control": "public, max-age=3600"
      }
    },
    {
      "src": "/sitemap.xml",
      "dest": "/sitemap.xml",
      "headers": {
        "Cache-Control": "public, max-age=3600",
        "Content-Type": "application/xml"
      }
    },

    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/404.html",
      "status": 404
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/og-image.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}
